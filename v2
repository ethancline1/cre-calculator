<script>
// ── UTILITIES ──────────────────────────────────
function fmt$(n){if(isNaN(n)||!isFinite(n))return'—';if(Math.abs(n)>=1e6)return'$'+(n/1e6).toFixed(2)+'M';if(Math.abs(n)>=1e3)return'$'+Math.round(n).toLocaleString();return'$'+n.toFixed(0);}
function fmtPct(n,d=1){if(isNaN(n)||!isFinite(n))return'—';return n.toFixed(d)+'%';}
function fmtX(n){if(isNaN(n)||!isFinite(n))return'—';return n.toFixed(2)+'x';}
function colorClass(v,t){if(v>=t[0])return'positive';if(v>=t[1])return'warning';return'negative';}
function flashEl(id){const e=document.getElementById(id);if(!e)return;e.classList.remove('value-update');void e.offsetWidth;e.classList.add('value-update');}

function calcAnnualDS(p,r,t){if(r===0)return p/t;const m=r/12,n=t*12,mo=p*m*Math.pow(1+m,n)/(Math.pow(1+m,n)-1);return mo*12;}
function loanBal(p,r,t,y){if(r===0)return p-(p/t)*y;const m=r/12,n=t*12,pd=y*12;return p*(Math.pow(1+m,n)-Math.pow(1+m,pd))/(Math.pow(1+m,n)-1);}
function calcIRR(cf){let r=0.1;for(let i=0;i<200;i++){let npv=0,dnpv=0;cf.forEach((v,t)=>{npv+=v/Math.pow(1+r,t);dnpv-=t*v/Math.pow(1+r,t+1);});if(Math.abs(npv)<.01)break;r-=npv/dnpv;if(r<-.99)r=-.99;}return r;}

function computeMetrics(price,dpPct,income,opex,rate,term,apprPct){
  const equity=price*dpPct/100, loan=price-equity;
  const ads=calcAnnualDS(loan,rate/100,term);
  const noi=income-opex;
  const capRate=price>0?noi/price*100:0;
  const cf=noi-ads;
  const coc=equity>0?cf/equity*100:0;
  const dscr=ads>0?noi/ads:0;
  const beo=income>0?(opex+ads)/income*100:0;
  const expRatio=income>0?opex/income*100:0;
  const flows=[-equity];
  for(let y=1;y<=5;y++){
    const pv=price*Math.pow(1+apprPct/100,y);
    const yi=income*Math.pow(1.03,y-1), yo=opex*Math.pow(1.025,y-1);
    const ycf=(yi-yo)-ads;
    if(y<5){flows.push(ycf);}
    else{const rem=loanBal(loan,rate/100,term,5);flows.push(ycf+pv-rem-pv*.05);}
  }
  const irr=calcIRR(flows)*100;
  let score=0;
  if(capRate>=6)score+=20;else if(capRate>=4)score+=10;
  if(coc>=8)score+=20;else if(coc>=4)score+=10;
  if(dscr>=1.5)score+=20;else if(dscr>=1.25)score+=10;
  if(irr>=15)score+=20;else if(irr>=10)score+=10;
  if(beo<70)score+=20;else if(beo<85)score+=10;
  return{equity,loan,ads,noi,capRate,cf,coc,dscr,beo,expRatio,irr,score};
}

// ── TIMESTAMP ──────────────────────────────────
function updateTime(){
  const n=new Date();
  document.getElementById('timestamp').textContent=
    n.toLocaleDateString('en-US',{month:'short',day:'2-digit',year:'numeric'})+
    '  '+n.toLocaleTimeString('en-US',{hour12:false});
  document.getElementById('printDate').textContent=
    'Generated: '+n.toLocaleString('en-US');
}
updateTime(); setInterval(updateTime,1000);

// ── TABS ───────────────────────────────────────
function switchTab(name,btn){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-'+name).classList.add('active');
  if(name==='scenarios') renderScenarios();
}

// ── MAIN CALCULATOR ────────────────────────────
const sliderPairs=[
  ['dpSlider','downPayment','dpLabel',v=>v.toFixed(1)+'%'],
  ['appSlider','appreciation','appLabel',v=>v.toFixed(1)+'%'],
  ['rateSlider','interestRate','rateLabel',v=>v.toFixed(2)+'%'],
  ['termSlider','loanTerm','termLabel',v=>v.toFixed(0)+' YRS'],
];
sliderPairs.forEach(([sid,iid,lid,fmt])=>{
  const sl=document.getElementById(sid),inp=document.getElementById(iid),lbl=document.getElementById(lid);
  sl.addEventListener('input',()=>{inp.value=sl.value;if(lbl)lbl.textContent=fmt(parseFloat(sl.value));calculate();});
  inp.addEventListener('input',()=>{sl.value=inp.value;if(lbl)lbl.textContent=fmt(parseFloat(inp.value)||0);calculate();});
});
['purchasePrice','rentalIncome','opex'].forEach(id=>document.getElementById(id).addEventListener('input',calculate));

function setResult(id,text,cls){const e=document.getElementById(id);if(!e)return;e.textContent=text;e.className='result-value '+(cls||'');}
function setSummary(id,text,cls){const e=document.getElementById(id);if(!e)return;e.textContent=text;e.className='metric-cell-value '+(cls||'');}
function setBar(bid,lid,pct,lt){const b=document.getElementById(bid),l=document.getElementById(lid);if(b)b.style.width=Math.min(Math.max(pct,0),100)+'%';if(l)l.textContent=lt;}

function calculate(){
  const price=parseFloat(document.getElementById('purchasePrice').value)||0;
  const dpPct=parseFloat(document.getElementById('downPayment').value)||0;
  const income=parseFloat(document.getElementById('rentalIncome').value)||0;
  const opex=parseFloat(document.getElementById('opex').value)||0;
  const rate=parseFloat(document.getElementById('interestRate').value)||0;
  const term=parseFloat(document.getElementById('loanTerm').value)||30;
  const apprPct=parseFloat(document.getElementById('appreciation').value)||0;
  const m=computeMetrics(price,dpPct,income,opex,rate,term,apprPct);

  document.getElementById('loanAmt').textContent=fmt$(m.loan);
  document.getElementById('annualDS').textContent=fmt$(m.ads);
  document.getElementById('expRatio').textContent=fmtPct(m.expRatio);

  setResult('r-noi',fmt$(m.noi),colorClass(m.noi,[0,-Infinity]));
  setSummary('sum-noi',fmt$(m.noi),colorClass(m.noi,[0,-Infinity]));
  setBar('bar-opex','bm-opex',m.expRatio,fmtPct(m.expRatio));

  const capCls=colorClass(m.capRate,[6,4]);
  setResult('r-cap',fmtPct(m.capRate),capCls); setSummary('sum-cap',fmtPct(m.capRate),capCls);
  setBar('bar-cap','bm-cap',m.capRate/10*100,fmtPct(m.capRate));

  const cocCls=colorClass(m.coc,[8,4]);
  setResult('r-coc',fmtPct(m.coc),cocCls); setSummary('sum-coc',fmtPct(m.coc),cocCls);
  setBar('bar-coc','bm-coc',m.coc/10*100,fmtPct(m.coc));

  const dCls=colorClass(m.dscr,[1.5,1.25]);
  setResult('r-dscr',fmtX(m.dscr),dCls); setSummary('sum-dscr',fmtX(m.dscr),dCls);
  setBar('bar-dscr','bm-dscr',m.dscr/2*100,fmtX(m.dscr));

  const iCls=colorClass(m.irr,[15,10]);
  setResult('r-irr',fmtPct(m.irr),iCls); setSummary('sum-irr',fmtPct(m.irr),iCls);
  setBar('bar-irr','bm-irr',m.irr/20*100,fmtPct(m.irr));

  const bCls=m.beo<70?'positive':m.beo<85?'warning':'negative';
  setResult('r-beo',fmtPct(m.beo),bCls); setSummary('sum-beo',fmtPct(m.beo),bCls);
  const sm=Math.max(0,100-m.beo);
  setBar('bar-beo','bm-beo',sm,fmtPct(sm)+' MARGIN');

  const se=document.getElementById('dealScore');
  se.textContent=m.score+'/100';
  se.style.color=m.score>=80?'var(--accent-green)':m.score>=50?'var(--accent-amber)':'var(--accent-red)';

  // Projection table
  const tbody=document.getElementById('projectionBody'); tbody.innerHTML='';
  for(let y=1;y<=5;y++){
    const pv=price*Math.pow(1+apprPct/100,y);
    const yi=income*Math.pow(1.03,y-1), yo=opex*Math.pow(1.025,y-1);
    const yn=yi-yo, ycf=yn-m.ads;
    const rem=loanBal(m.loan,rate/100,term,y), eq=pv-rem;
    const tr=document.createElement('tr');
    tr.innerHTML=`<td>YEAR ${y}</td><td>${fmt$(pv)}</td><td>${fmt$(yi)}</td><td class="${yn>=0?'positive-td':'warning-td'}">${fmt$(yn)}</td><td>${fmt$(m.ads)}</td><td class="${ycf>=0?'positive-td':'warning-td'}">${fmt$(ycf)}</td><td class="positive-td">${fmt$(eq)}</td>`;
    tbody.appendChild(tr);
  }

  // CF chart
  const ce=document.getElementById('cfChart'); ce.innerHTML='';
  const cfs=[1,2,3,4,5].map(y=>{const yi=income*Math.pow(1.03,y-1),yo=opex*Math.pow(1.025,y-1);return yi-yo-m.ads;});
  const maxA=Math.max(...cfs.map(Math.abs),1);
  cfs.forEach((cf,i)=>{
    const pct=Math.abs(cf)/maxA*100;
    const row=document.createElement('div'); row.className='cf-year-row';
    row.innerHTML=`<div class="cf-year-label">YR ${i+1}</div><div class="cf-bar-track"><div class="cf-bar-fill ${cf<0?'negative':''}" style="width:${pct}%"></div></div><div class="cf-value ${cf>=0?'':'negative-td'}">${fmt$(cf)}</div>`;
    ce.appendChild(row);
  });

  ['sum-noi','sum-cap','sum-coc','sum-dscr','sum-irr','sum-beo'].forEach(flashEl);
}
calculate();

// ── SCENARIO COMPARISON ─────────────────────────
const scenarioDefaults=[
  {name:'CONSERVATIVE',price:2000000,dp:30,income:180000,opex:50000,rate:7,term:30,appr:2},
  {name:'BASE CASE',price:2500000,dp:25,income:220000,opex:55000,rate:6.5,term:30,appr:3},
  {name:'AGGRESSIVE',price:3000000,dp:20,income:290000,opex:65000,rate:6,term:30,appr:5},
];

function scInputHtml(id,prefix,val){
  return `<div class="input-row"><span class="input-prefix">${prefix}</span><input type="number" id="${id}" value="${val}" oninput="recalcScenarios()"></div>`;
}

function renderScenarios(){
  const grid=document.getElementById('scenarioGrid'); grid.innerHTML='';
  const labels=['SCENARIO A','SCENARIO B','SCENARIO C'];
  scenarioDefaults.forEach((s,i)=>{
    const card=document.createElement('div'); card.className='scenario-card';
    card.innerHTML=`
      <div class="scenario-label">${labels[i]}</div>
      <div class="scenario-name-row">
        <input class="scenario-name-input" id="sc${i}-name" value="${s.name}" oninput="recalcScenarios()" placeholder="Scenario name">
      </div>
      <div class="scenario-inputs">
        <div class="sc-field"><label>Purchase Price</label>${scInputHtml('sc'+i+'-price','$',s.price)}</div>
        <div class="sc-field"><label>Down Payment %</label>${scInputHtml('sc'+i+'-dp','%',s.dp)}</div>
        <div class="sc-field"><label>Annual Income</label>${scInputHtml('sc'+i+'-income','$',s.income)}</div>
        <div class="sc-field"><label>Annual OPEX</label>${scInputHtml('sc'+i+'-opex','$',s.opex)}</div>
        <div class="sc-field"><label>Interest Rate %</label>${scInputHtml('sc'+i+'-rate','%',s.rate)}</div>
        <div class="sc-field"><label>Loan Term (Yrs)</label>${scInputHtml('sc'+i+'-term','YR',s.term)}</div>
        <div class="sc-field"><label>Appreciation %</label>${scInputHtml('sc'+i+'-appr','%',s.appr)}</div>
      </div>
      <div class="scenario-results" id="sc${i}-results"></div>
    `;
    grid.appendChild(card);
  });
  recalcScenarios();
}

function getScVal(i,field){return parseFloat(document.getElementById('sc'+i+'-'+field)?.value)||0;}

function recalcScenarios(){
  const allMetrics=[];
  for(let i=0;i<3;i++){
    const m=computeMetrics(
      getScVal(i,'price'),getScVal(i,'dp'),getScVal(i,'income'),
      getScVal(i,'opex'),getScVal(i,'rate'),getScVal(i,'term')||30,getScVal(i,'appr')
    );
    allMetrics.push(m);

    const cls=m.score>=80?'var(--accent-green)':m.score>=50?'var(--accent-amber)':'var(--accent-red)';
    const el=document.getElementById('sc'+i+'-results');
    if(!el)continue;
    el.innerHTML=`
      <div class="sc-metric-row"><span class="sc-metric-name">NOI</span><span class="sc-metric-val ${colorClass(m.noi,[0,-Infinity])}">${fmt$(m.noi)}</span></div>
      <div class="sc-metric-row"><span class="sc-metric-name">CAP RATE</span><span class="sc-metric-val ${colorClass(m.capRate,[6,4])}">${fmtPct(m.capRate)}</span></div>
      <div class="sc-metric-row"><span class="sc-metric-name">COC RETURN</span><span class="sc-metric-val ${colorClass(m.coc,[8,4])}">${fmtPct(m.coc)}</span></div>
      <div class="sc-metric-row"><span class="sc-metric-name">DSCR</span><span class="sc-metric-val ${colorClass(m.dscr,[1.5,1.25])}">${fmtX(m.dscr)}</span></div>
      <div class="sc-metric-row"><span class="sc-metric-name">5-YR IRR</span><span class="sc-metric-val ${colorClass(m.irr,[15,10])}">${fmtPct(m.irr)}</span></div>
      <div class="sc-metric-row"><span class="sc-metric-name">BREAK-EVEN OCC.</span><span class="sc-metric-val ${m.beo<70?'positive':m.beo<85?'warning':'negative'}">${fmtPct(m.beo)}</span></div>
      <div class="sc-score-row">
        <span class="sc-score-label">DEAL SCORE</span>
        <span class="sc-score-val" style="color:${cls}">${m.score}/100</span>
      </div>
      <div class="sc-bar-row"><div class="sc-bar-bg"><div class="sc-bar-fill" style="width:${m.score}%"></div></div></div>
    `;
  }

  // Update comparison table
  const names=[0,1,2].map(i=>document.getElementById('sc'+i+'-name')?.value||('S'+(i+1)));
  [0,1,2].forEach(i=>{const e=document.getElementById('col-s'+(i+1));if(e)e.textContent=names[i];});

  const metrics=[
    {label:'NOI',vals:allMetrics.map(m=>m.noi),fmt:fmt$,higher:true},
    {label:'CAP RATE',vals:allMetrics.map(m=>m.capRate),fmt:fmtPct,higher:true},
    {label:'CASH-ON-CASH',vals:allMetrics.map(m=>m.coc),fmt:fmtPct,higher:true},
    {label:'DSCR',vals:allMetrics.map(m=>m.dscr),fmt:fmtX,higher:true},
    {label:'5-YR IRR',vals:allMetrics.map(m=>m.irr),fmt:fmtPct,higher:true},
    {label:'BREAK-EVEN OCC.',vals:allMetrics.map(m=>m.beo),fmt:fmtPct,higher:false},
    {label:'DEAL SCORE',vals:allMetrics.map(m=>m.score),fmt:v=>v+'/100',higher:true},
  ];

  const scColors=['winner-s1','winner-s2','winner-s3'];
  const tbody=document.getElementById('comparisonBody'); tbody.innerHTML='';
  metrics.forEach(({label,vals,fmt,higher})=>{
    const best=higher?Math.max(...vals):Math.min(...vals);
    const tr=document.createElement('tr');
    const cells=vals.map((v,i)=>{
      const w=v===best;
      return `<td class="${w?'winner '+scColors[i]:''}">${fmt(v)}${w?' ▲':''}</td>`;
    });
    tr.innerHTML=`<td>${label}</td>${cells.join('')}`;
    tbody.appendChild(tr);
  });
}

// ── PDF EXPORT ─────────────────────────────────
function exportPDF(){
  // Make both tabs visible for print
  document.querySelectorAll('.tab-content').forEach(t=>t.style.display='block');
  window.print();
  setTimeout(()=>{
    document.querySelectorAll('.tab-content').forEach(t=>t.style.display='');
    document.querySelector('.tab-content.active').style.display='block';
  },1000);
}
</script>

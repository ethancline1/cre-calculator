<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>CRE Investment Calculator v2</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap');

:root {
  --bg-primary: #0a0f1e;
  --bg-card: #0f1830;
  --bg-input: #080d1a;
  --border: #1a2540;
  --border-bright: #1e2d50;
  --accent-blue: #0066ff;
  --accent-cyan: #00b4d8;
  --accent-green: #00e676;
  --accent-amber: #ffab00;
  --accent-red: #ff1744;
  --text-primary: #e8eaf6;
  --text-secondary: #8892a4;
  --text-dim: #4a5568;
  --glow-blue: rgba(0,102,255,0.15);
  --s1: #0066ff; --s2: #00b4d8; --s3: #a855f7;
}

* { margin:0; padding:0; box-sizing:border-box; }

body {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: 'IBM Plex Mono', monospace;
  font-size: 13px;
  min-height: 100vh;
  overflow-x: hidden;
}

body::before {
  content:''; position:fixed; inset:0;
  background: repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.03) 2px,rgba(0,0,0,.03) 4px);
  pointer-events:none; z-index:1000;
}
body::after {
  content:''; position:fixed; inset:0;
  background-image: linear-gradient(rgba(0,102,255,.03) 1px,transparent 1px), linear-gradient(90deg,rgba(0,102,255,.03) 1px,transparent 1px);
  background-size:40px 40px; pointer-events:none; z-index:0;
}

.container { position:relative; z-index:1; max-width:1340px; margin:0 auto; padding:16px; }

/* ── HEADER ── */
.header {
  display:flex; align-items:center; justify-content:space-between;
  border-bottom:1px solid var(--border-bright); padding-bottom:12px; margin-bottom:20px;
  flex-wrap:wrap; gap:10px;
}
.header-left { display:flex; align-items:center; gap:12px; }
.terminal-badge {
  background:var(--accent-blue); color:#fff; font-size:10px; font-weight:600;
  letter-spacing:.12em; padding:3px 8px;
  clip-path:polygon(0 0,calc(100% - 6px) 0,100% 50%,calc(100% - 6px) 100%,0 100%);
  white-space:nowrap;
}
.header-title { font-family:'IBM Plex Sans',sans-serif; font-size:16px; font-weight:600; letter-spacing:.04em; }
.header-title span { color:var(--accent-blue); }
.header-right { display:flex; align-items:center; gap:14px; flex-wrap:wrap; }
.live-indicator { display:flex; align-items:center; gap:6px; font-size:10px; color:var(--accent-green); letter-spacing:.1em; }
.live-dot { width:6px; height:6px; border-radius:50%; background:var(--accent-green); animation:pulse 1.5s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,230,118,.4)} 50%{opacity:.7;box-shadow:0 0 0 4px rgba(0,230,118,0)} }
.timestamp { font-size:10px; color:var(--text-dim); }

/* ── EXPORT BUTTON ── */
.btn-export {
  display:flex; align-items:center; gap:6px;
  background:transparent; border:1px solid var(--accent-cyan); color:var(--accent-cyan);
  font-family:'IBM Plex Mono',monospace; font-size:10px; font-weight:600;
  letter-spacing:.1em; padding:6px 14px; cursor:pointer; transition:all .2s;
  white-space:nowrap;
}
.btn-export:hover { background:var(--accent-cyan); color:#000; }
.btn-export svg { flex-shrink:0; }

/* ── TABS ── */
.tabs { display:flex; gap:0; margin-bottom:20px; border-bottom:1px solid var(--border-bright); overflow-x:auto; }
.tab-btn {
  background:transparent; border:none; color:var(--text-dim);
  font-family:'IBM Plex Mono',monospace; font-size:11px; letter-spacing:.1em;
  padding:10px 20px; cursor:pointer; border-bottom:2px solid transparent;
  transition:all .2s; white-space:nowrap;
}
.tab-btn:hover { color:var(--text-secondary); }
.tab-btn.active { color:var(--accent-blue); border-bottom-color:var(--accent-blue); }
.tab-content { display:none; }
.tab-content.active { display:block; }

/* ── METRICS SUMMARY ── */
.metrics-summary {
  background:var(--bg-card); border:1px solid var(--border-bright);
  border-top:2px solid var(--accent-blue); margin-bottom:20px;
  position:relative; overflow:hidden;
}
.metrics-summary::before {
  content:''; position:absolute; inset:0;
  background:linear-gradient(135deg,var(--glow-blue) 0%,transparent 60%);
  pointer-events:none;
}
.metrics-header {
  display:flex; align-items:center; justify-content:space-between;
  padding:10px 16px; border-bottom:1px solid var(--border); flex-wrap:wrap; gap:8px;
}
.metrics-label { font-size:10px; letter-spacing:.15em; color:var(--accent-blue); font-weight:600; }
.deal-score { display:flex; align-items:center; gap:8px; font-size:10px; color:var(--text-secondary); }
.score-value { font-size:14px; font-weight:600; color:var(--accent-green); transition:color .3s; }
.metrics-grid { display:grid; grid-template-columns:repeat(6,1fr); }
.metric-cell { padding:14px 12px; border-right:1px solid var(--border); position:relative; }
.metric-cell:last-child { border-right:none; }
.metric-cell-label { font-size:9px; letter-spacing:.1em; color:var(--text-dim); text-transform:uppercase; margin-bottom:6px; }
.metric-cell-value { font-size:18px; font-weight:500; color:var(--text-primary); transition:all .3s; line-height:1; }
.metric-cell-sub { font-size:9px; color:var(--text-secondary); margin-top:4px; }
.metric-cell-value.positive{color:var(--accent-green)} .metric-cell-value.warning{color:var(--accent-amber)} .metric-cell-value.negative{color:var(--accent-red)}
@keyframes flash { 0%{background:rgba(0,102,255,.2)} 100%{background:transparent} }
.value-update { animation:flash .4s ease; }

/* ── MAIN GRID ── */
.main-grid { display:grid; grid-template-columns:380px 1fr; gap:20px; }
.input-panel { display:flex; flex-direction:column; gap:16px; }
.output-panel { display:flex; flex-direction:column; gap:16px; }

/* ── PANEL ── */
.panel { background:var(--bg-card); border:1px solid var(--border-bright); }
.panel-header {
  display:flex; align-items:center; gap:8px; padding:8px 14px;
  border-bottom:1px solid var(--border); background:rgba(0,0,0,.2);
}
.panel-header-dot { width:8px; height:8px; background:var(--accent-blue); clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%); }
.panel-title { font-size:10px; letter-spacing:.15em; color:var(--accent-blue); font-weight:600; text-transform:uppercase; }
.panel-body { padding:16px; }

/* ── INPUTS ── */
.input-group { margin-bottom:14px; }
.input-group:last-child { margin-bottom:0; }
.input-label { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:5px; }
.input-label-text { font-size:10px; letter-spacing:.08em; color:var(--text-secondary); text-transform:uppercase; }
.input-label-unit { font-size:9px; color:var(--text-dim); }
.input-row {
  display:flex; align-items:center;
  background:var(--bg-input); border:1px solid var(--border);
  transition:border-color .2s,box-shadow .2s;
}
.input-row:focus-within { border-color:var(--accent-blue); box-shadow:0 0 0 2px rgba(0,102,255,.1); }
.input-prefix {
  padding:8px 10px; font-size:12px; color:var(--text-dim);
  border-right:1px solid var(--border); background:rgba(0,0,0,.2);
  user-select:none; min-width:32px; text-align:center;
}
.input-row input {
  flex:1; background:transparent; border:none; outline:none;
  color:var(--text-primary); font-family:'IBM Plex Mono',monospace;
  font-size:13px; padding:8px 10px; width:100%; min-width:0;
}
.input-row input::placeholder { color:var(--text-dim); }
.input-slider {
  width:100%; margin-top:6px; -webkit-appearance:none;
  height:2px; background:var(--border-bright); outline:none; cursor:pointer;
}
.input-slider::-webkit-slider-thumb {
  -webkit-appearance:none; width:12px; height:12px; background:var(--accent-blue);
  clip-path:polygon(50% 0%,100% 50%,50% 100%,0% 50%); cursor:pointer; transition:transform .2s;
}
.input-slider::-webkit-slider-thumb:hover { transform:scale(1.3); }
.input-divider { display:flex; align-items:center; gap:8px; margin:12px 0; }
.input-divider-line { flex:1; height:1px; background:var(--border); }
.input-divider-text { font-size:9px; color:var(--text-dim); letter-spacing:.12em; }

/* ── RESULTS ── */
.results-grid { display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--border); }
.result-block { background:var(--bg-card); padding:16px; position:relative; overflow:hidden; transition:background .3s; }
.result-block::after {
  content:''; position:absolute; bottom:0; left:0; right:0; height:2px;
  background:var(--accent-blue); transform:scaleX(0); transform-origin:left; transition:transform .4s;
}
.result-block:hover::after { transform:scaleX(1); }
.result-block-tag {
  font-size:9px; letter-spacing:.14em; color:var(--text-dim);
  text-transform:uppercase; margin-bottom:8px;
  display:flex; align-items:center; gap:6px;
}
.result-block-tag::before { content:''; display:inline-block; width:4px; height:4px; background:var(--accent-cyan); }
.result-value { font-size:30px; font-weight:500; line-height:1; color:var(--text-primary); transition:all .3s; margin-bottom:4px; }
.result-value.positive{color:var(--accent-green)} .result-value.warning{color:var(--accent-amber)} .result-value.negative{color:var(--accent-red)}
.result-desc { font-size:10px; color:var(--text-secondary); line-height:1.4; }
.result-benchmark { margin-top:8px; padding-top:8px; border-top:1px solid var(--border); font-size:9px; color:var(--text-dim); display:flex; align-items:center; gap:6px; }
.benchmark-bar-bg { flex:1; height:3px; background:var(--border-bright); position:relative; overflow:hidden; }
.benchmark-bar-fill { position:absolute; left:0; top:0; height:100%; background:var(--accent-blue); transition:width .5s ease; max-width:100%; }

/* ── TOOLTIP ── */
.tooltip-wrap { position:relative; display:inline-flex; align-items:center; gap:5px; }
.tip-icon {
  display:inline-flex; align-items:center; justify-content:center;
  width:14px; height:14px; border-radius:50%;
  border:1px solid var(--text-dim); color:var(--text-dim);
  font-size:9px; cursor:help; flex-shrink:0; transition:all .2s;
}
.tip-icon:hover { border-color:var(--accent-cyan); color:var(--accent-cyan); }
.tooltip-box {
  visibility:hidden; opacity:0;
  position:absolute; bottom:calc(100% + 8px); left:50%; transform:translateX(-50%);
  background:#1a2540; border:1px solid var(--border-bright);
  color:var(--text-primary); font-size:11px; line-height:1.5;
  padding:10px 12px; width:220px; z-index:999;
  transition:opacity .2s; pointer-events:none;
  font-family:'IBM Plex Sans',sans-serif; font-weight:400;
}
.tooltip-box::after {
  content:''; position:absolute; top:100%; left:50%; transform:translateX(-50%);
  border:5px solid transparent; border-top-color:#1a2540;
}
.tooltip-wrap:hover .tooltip-box { visibility:visible; opacity:1; }
.tooltip-label { font-size:10px; font-weight:600; color:var(--accent-cyan); letter-spacing:.08em; margin-bottom:4px; font-family:'IBM Plex Mono',monospace; }
.tooltip-formula { font-size:9px; color:var(--text-dim); margin-top:6px; border-top:1px solid var(--border); padding-top:6px; font-family:'IBM Plex Mono',monospace; }

/* ── PROJECTION TABLE ── */
.projection-table { width:100%; border-collapse:collapse; }
.projection-table th {
  font-size:9px; letter-spacing:.12em; color:var(--text-dim); text-transform:uppercase;
  padding:6px 10px; text-align:right; border-bottom:1px solid var(--border);
}
.projection-table th:first-child { text-align:left; }
.projection-table td {
  padding:7px 10px; font-size:12px; text-align:right;
  color:var(--text-secondary); border-bottom:1px solid rgba(26,37,64,.5); transition:all .3s;
}
.projection-table td:first-child { text-align:left; color:var(--text-dim); font-size:10px; }
.projection-table tr:last-child td { border-bottom:none; }
.projection-table tr:hover td { background:rgba(0,102,255,.04); color:var(--text-primary); }
.positive-td{color:var(--accent-green)!important} .warning-td{color:var(--accent-amber)!important} .negative-td{color:var(--accent-red)!important}

/* ── CASHFLOW CHART ── */
.cashflow-chart { padding:16px; display:flex; flex-direction:column; gap:10px; }
.cf-year-row { display:flex; align-items:center; gap:10px; }
.cf-year-label { font-size:10px; color:var(--text-dim); width:36px; text-align:right; flex-shrink:0; }
.cf-bar-track { flex:1; height:18px; background:var(--bg-input); border:1px solid var(--border); position:relative; overflow:hidden; }
.cf-bar-fill { position:absolute; left:0; top:0; bottom:0; background:linear-gradient(90deg,var(--accent-blue),var(--accent-cyan)); transition:width .6s cubic-bezier(.4,0,.2,1); }
.cf-bar-fill.negative { background:linear-gradient(90deg,var(--accent-red),#ff6b6b); }
.cf-value { font-size:11px; color:var(--text-secondary); width:80px; text-align:right; flex-shrink:0; }

/* ── STATUS BAR ── */
.status-bar {
  display:flex; align-items:center; justify-content:space-between;
  padding:8px 16px; border-top:1px solid var(--border);
  background:rgba(0,0,0,.3); font-size:9px; color:var(--text-dim); letter-spacing:.08em;
  flex-wrap:wrap; gap:6px;
}
.status-item { display:flex; align-items:center; gap:6px; }
.status-dot { width:4px; height:4px; border-radius:50%; background:var(--text-dim); }
.status-dot.active { background:var(--accent-green); }

/* ── SCENARIO COMPARISON ── */
.scenario-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:20px; }
.scenario-card { background:var(--bg-card); border:1px solid var(--border-bright); position:relative; overflow:hidden; }
.scenario-card.active { border-color:var(--s1); }
.scenario-card:nth-child(2) { border-top:2px solid var(--s2); }
.scenario-card:nth-child(3) { border-top:2px solid var(--s3); }
.scenario-card:nth-child(1) { border-top:2px solid var(--s1); }
.scenario-label {
  font-size:9px; letter-spacing:.15em; font-weight:600; padding:8px 14px 6px;
  border-bottom:1px solid var(--border); background:rgba(0,0,0,.2);
}
.scenario-card:nth-child(1) .scenario-label { color:var(--s1); }
.scenario-card:nth-child(2) .scenario-label { color:var(--s2); }
.scenario-card:nth-child(3) .scenario-label { color:var(--s3); }
.scenario-name-row {
  display:flex; align-items:center; gap:8px; padding:8px 12px;
  border-bottom:1px solid var(--border);
}
.scenario-name-input {
  flex:1; background:transparent; border:none; outline:none;
  color:var(--text-primary); font-family:'IBM Plex Mono',monospace;
  font-size:11px; min-width:0;
}
.scenario-inputs { padding:12px; display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.sc-field label { font-size:8px; color:var(--text-dim); letter-spacing:.1em; text-transform:uppercase; display:block; margin-bottom:3px; }
.sc-field .input-row { background:var(--bg-input); }
.sc-field .input-row input { font-size:12px; padding:6px 8px; }
.sc-field .input-prefix { padding:6px 8px; font-size:11px; }
.scenario-results { padding:12px; border-top:1px solid var(--border); }
.sc-metric-row { display:flex; justify-content:space-between; align-items:center; padding:4px 0; border-bottom:1px solid rgba(26,37,64,.4); }
.sc-metric-row:last-child { border-bottom:none; }
.sc-metric-name { font-size:9px; color:var(--text-dim); letter-spacing:.08em; }
.sc-metric-val { font-size:13px; font-weight:500; }
.sc-score-row { display:flex; justify-content:space-between; align-items:center; padding:10px 0 4px; }
.sc-score-label { font-size:9px; color:var(--text-dim); letter-spacing:.1em; }
.sc-score-val { font-size:18px; font-weight:600; }
.sc-bar-row { margin-top:4px; }
.sc-bar-bg { height:4px; background:var(--border-bright); }
.sc-bar-fill { height:100%; transition:width .6s ease; }
.scenario-card:nth-child(1) .sc-bar-fill { background:var(--s1); }
.scenario-card:nth-child(2) .sc-bar-fill { background:var(--s2); }
.scenario-card:nth-child(3) .sc-bar-fill { background:var(--s3); }

/* ── COMPARISON TABLE ── */
.comparison-table { width:100%; border-collapse:collapse; }
.comparison-table th {
  font-size:9px; letter-spacing:.12em; color:var(--text-dim); text-transform:uppercase;
  padding:8px 12px; border-bottom:1px solid var(--border); text-align:left;
}
.comparison-table th:nth-child(2){color:var(--s1)} .comparison-table th:nth-child(3){color:var(--s2)} .comparison-table th:nth-child(4){color:var(--s3)}
.comparison-table td { padding:8px 12px; font-size:12px; border-bottom:1px solid rgba(26,37,64,.4); }
.comparison-table tr:last-child td { border-bottom:none; }
.comparison-table tr:hover td { background:rgba(0,102,255,.04); }
.comparison-table td:first-child { font-size:10px; color:var(--text-dim); }
.winner { font-weight:600; }
.winner-s1 { color:var(--s1); } .winner-s2 { color:var(--s2); } .winner-s3 { color:var(--s3); }

/* ── MOBILE ── */
@media (max-width:900px) {
  .main-grid { grid-template-columns:1fr; }
  .metrics-grid { grid-template-columns:repeat(3,1fr); }
  .metric-cell { border-bottom:1px solid var(--border); }
  .metric-cell:nth-child(3){ border-right:none; }
  .metric-cell:nth-child(4),
  .metric-cell:nth-child(5),
  .metric-cell:nth-child(6){ border-bottom:none; }
  .scenario-grid { grid-template-columns:1fr; }
  .header-title { font-size:13px; }
}
@media (max-width:600px) {
  .container { padding:10px; }
  .metrics-grid { grid-template-columns:repeat(2,1fr); }
  .metric-cell:nth-child(2){ border-right:1px solid var(--border); }
  .metric-cell:nth-child(3){ border-right:none; border-bottom:1px solid var(--border); }
  .metric-cell:nth-child(4){ border-right:1px solid var(--border); border-bottom:1px solid var(--border); }
  .metric-cell:nth-child(5){ border-right:none; border-bottom:1px solid var(--border); }
  .metric-cell:nth-child(6){ border-right:none; border-bottom:none; }
  .results-grid { grid-template-columns:1fr; }
  .header-title { display:none; }
  .terminal-badge { font-size:9px; }
  .tab-btn { padding:10px 12px; font-size:10px; }
  .result-value { font-size:24px; }
  .scenario-inputs { grid-template-columns:1fr; }
  .status-bar { font-size:8px; }
  .status-bar > div:last-child { display:none; }
}

/* ── PRINT / PDF ── */
@media print {
  body { background:#fff !important; color:#000 !important; font-size:11px; }
  body::before, body::after { display:none; }
  .tabs, .btn-export, .input-panel, .tab-btn, .status-bar { display:none !important; }
  .tab-content { display:block !important; }
  :root {
    --bg-card:#fff; --bg-primary:#fff; --border:#ccc; --border-bright:#bbb;
    --text-primary:#000; --text-secondary:#444; --text-dim:#777;
    --accent-blue:#003399; --accent-cyan:#006688; --accent-green:#006600;
    --accent-amber:#885500; --accent-red:#cc0000;
  }
  .main-grid { grid-template-columns:1fr; }
  .metrics-summary { border:2px solid #003399; }
  .panel { border:1px solid #ccc; page-break-inside:avoid; }
  .metrics-grid { grid-template-columns:repeat(6,1fr); }
  .scenario-grid { grid-template-columns:repeat(3,1fr); }
  .print-header {
    display:block !important;
    text-align:center; padding:16px 0; border-bottom:2px solid #003399; margin-bottom:20px;
  }
  .print-header h1 { font-size:20px; color:#003399; font-family:'IBM Plex Sans',sans-serif; }
  .print-header p { font-size:10px; color:#777; margin-top:4px; }
  body::before { display:none; }
}
.print-header { display:none; }
</style>
</head>
<body>

<div class="container">

  <!-- PRINT-ONLY HEADER -->
  <div class="print-header">
    <h1>CRE Investment Analysis Report</h1>
    <p id="printDate"></p>
  </div>

  <!-- HEADER -->
  <div class="header">
    <div class="header-left">
      <div class="terminal-badge">CRE ANALYTICS</div>
      <div class="header-title">COMMERCIAL <span>REAL ESTATE</span> CALCULATOR</div>
    </div>
    <div class="header-right">
      <div class="live-indicator"><div class="live-dot"></div> LIVE CALC</div>
      <div class="timestamp" id="timestamp"></div>
      <button class="btn-export" onclick="exportPDF()">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        EXPORT PDF
      </button>
    </div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab-btn active" onclick="switchTab('calculator',this)">▶ CALCULATOR</button>
    <button class="tab-btn" onclick="switchTab('scenarios',this)">⊞ SCENARIO COMPARISON</button>
  </div>

  <!-- ══════════════════════════════════════════ -->
  <!-- TAB 1: CALCULATOR                          -->
  <!-- ══════════════════════════════════════════ -->
  <div class="tab-content active" id="tab-calculator">

    <!-- KEY METRICS SUMMARY -->
    <div class="metrics-summary">
      <div class="metrics-header">
